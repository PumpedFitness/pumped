{
  "name": "pumped",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "frontend": "bun run --cwd apps/frontend start",
    "frontend:ios": "bun run --cwd apps/frontend ios",
    "frontend:android": "bun run --cwd apps/frontend android",
    "frontend:lint": "bun run --cwd apps/frontend lint",
    "frontend:lint:fix": "bun run --cwd apps/frontend lint:fix",
    "frontend:format": "bun run --cwd apps/frontend format",
    "frontend:format:check": "bun run --cwd apps/frontend format:check",
    "frontend:test": "bun run --cwd apps/frontend test",
    "backend": "docker compose -f apps/backend/docker-compose.dev.yml up -d && ./apps/backend/gradlew -p apps/backend bootRun",
    "backend:build": "./apps/backend/gradlew -p apps/backend build",
    "backend:test": "./apps/backend/gradlew -p apps/backend test",
    "backend:restart": "lsof -ti :8080 | xargs kill -9 2>/dev/null; docker compose -f apps/backend/docker-compose.dev.yml up -d && ./apps/backend/gradlew -p apps/backend bootRun",
    "services:up": "docker compose -f apps/backend/docker-compose.dev.yml up -d",
    "services:down": "docker compose -f apps/backend/docker-compose.dev.yml down",
    "services:logs": "docker compose -f apps/backend/docker-compose.dev.yml logs -f",
    "frontend:prepare": "bun run --cwd apps/frontend dev:prepare",
    "frontend:generate": "bun run --cwd apps/frontend generate",
    "frontend:schema:generate": "bun run --cwd apps/frontend schema:generate",
    "frontend:api:fetch": "curl -sf -u admin:admin http://localhost:8080/v3/api-docs -o apps/frontend/openapi.json",
    "frontend:api:generate": "bun run --cwd apps/frontend api:generate",
    "install:all": "bun install"
  },
  "dependencies": {
    "all": "^0.0.0"
  }
}
