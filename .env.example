# =============================================================================
# Pumped — GitHub Actions Secrets
# =============================================================================
# Copy this file to .env, fill in your values, then run:
#   ./toolbox/push-secrets.sh
#
# Lines starting with # are ignored. Keys with empty values are skipped.
# =============================================================================

# -----------------------------------------------------------------------------
# Server SSH access
# -----------------------------------------------------------------------------

# IP address or hostname of your VPS
SSH_HOST=

# SSH user on the VPS (e.g. ubuntu, root)
SSH_USER=

# Contents of your private key file — multiline values must be wrapped in double quotes
SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----
paste your key here
-----END OPENSSH PRIVATE KEY-----"

# -----------------------------------------------------------------------------
# Database (MariaDB)
# -----------------------------------------------------------------------------

# Root password — only needed during bootstrap
DB_ROOT_PASSWORD=

# Application user credentials — used by the backend at runtime
DB_USER=
DB_PASSWORD=

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------

# Minimum 256-bit random string. Generate one with:
#   openssl rand -hex 64
JWT_SECRET=
