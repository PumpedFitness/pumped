{
  "name": "pumped-frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "bun run dev:prepare && expo run:android",
    "ios": "bun run dev:prepare && expo run:ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "start": "bun run dev:prepare && react-native start",
    "test": "jest",
    "dev:prepare": "bun run scripts/prepare.ts",
    "api:fetch": "curl -sf -u admin:admin http://localhost:8080/v3/api-docs -o openapi.json",
    "api:generate": "orval",
    "schema:generate": "bun run scripts/generate-schema.ts",
    "migrations:generate": "bun run scripts/generate-migrations.ts",
    "generate": "bun run api:fetch && bun run api:generate && bun run schema:generate && bun run migrations:generate"
  },
  "dependencies": {
    "@react-native/new-app-screen": "0.85.2",
    "@react-navigation/bottom-tabs": "^7.15.11",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.12",
    "all": "^0.0.0",
    "babel-preset-expo": "~55.0.8",
    "drizzle-orm": "^0.45.2",
    "expo": "^55.0.19",
    "expo-crypto": "~55.0.14",
    "expo-sqlite": "^55.0.15",
    "heroui-native": "^1.0.2",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.6",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.4",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "uniwind": "^1.6.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@eslint/js": "^10.0.1",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.2",
    "@react-native/jest-preset": "0.85.2",
    "@react-native/metro-config": "0.85.2",
    "@react-native/typescript-config": "0.85.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "ajv": "^8.20.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "jest": "^29.6.3",
    "node-sql-parser": "^5.4.0",
    "orval": "^8.9.0",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.1"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
